{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/education-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://onlineschoolbackend-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
