# Скопіюйте в .env і підставте свої значення. Файл .env не комітиться в Git.
#
# Production-збірка (npm run build): змінні також можна задати в Vercel → Settings → Environment Variables.

# URL API для production (наприклад https://your-api.onrender.com або /api з проксі на Vercel)
NG_APP_API_URL=/api

# Локальний вхід суперадміна без бекенду — на Vercel зазвичай false (вхід через /auth/login і користувача в БД)
ENABLE_LOCAL_SUPER_ADMIN=false

# Лише якщо ENABLE_LOCAL_SUPER_ADMIN=true (обидва обовʼязкові)
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
