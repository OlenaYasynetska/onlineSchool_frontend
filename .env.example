# Скопіюйте в .env і підставте значення. Файл .env у git не потрапляє.
# Застосовується при npm run build (prebuild → scripts/generate-prod-env.mjs).

# NG_APP_API_URL=/api

# Локальний вхід суперадміна без бекенду (у production збірці за замовчуванням вимкнено).
# ENABLE_LOCAL_SUPER_ADMIN=true
# SUPER_ADMIN_EMAIL=superadmin@education.local
# SUPER_ADMIN_PASSWORD=SuperAdmin!ChangeMe
